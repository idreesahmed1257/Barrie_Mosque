{
    "version": 2,
    "builds": [
        {
            "src": "/server.js",
            "use": "@vercel/node"
        },
        {
            "src": "/out/**/*",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/server.js"
        },
        {
            "src": "/(.*)",
            "dest": "/out/$1"
        }
    ]
}